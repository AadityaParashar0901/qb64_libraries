Function Base32Decode$ (__I$)
    Dim As _Unsigned _Byte B, J
    Dim As _Unsigned Long O_OFFSET
    O$ = ""
    B32$ = "ABCDEFGHIJKLMNOPQRSTUVWXYZ234567"
    __I2$ = UCase$(__I$)
    For I = 1 To Len(__I2$)
        B = Asc(__I2$, I)
        If B = 61 Then Exit For
        B = InStr(B32$, Chr$(B))
        If B = 0 Then Exit For
        PutBitBufferMSB O$, O_OFFSET, B - 1, 5, J
    Next I
    Base32Decode$ = Left$(O$, O_OFFSET)
End Function
